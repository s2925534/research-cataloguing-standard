# Copy this file to instance/.env and fill in real values for your machine.
# instance/.env holds machine-specific / sensitive settings. Project taxonomy
# and vocabulary belong in instance/project_config.json instead.

# One or more source roots to scan, comma-separated absolute paths.
SOURCE_DATA_ROOTS=/absolute/path/to/_ResearchData

# Where catalogued/renamed working copies and catalogue outputs are written.
# Keep this under instance/ so outputs stay gitignored.
OUTPUT_ROOT=/absolute/path/to/this/repo/instance

# Enable OCR fallback for images/screenshots when text extraction fails or is not applicable (true/false).
OCR_ENABLED=false

# Hash algorithm used for immutable file fingerprinting.
HASH_ALGORITHM=sha256

# Confidence threshold below which human_review_required is forced true (0-1).
REVIEW_CONFIDENCE_THRESHOLD=0.90

# Optional. Only used by catalogue.py rename-plan as a last-resort naming
# fallback, when a file has neither embedded title metadata nor a usable
# original filename. Leave unset to skip AI naming entirely (falls back to
# catalogue_id, which is always unique and traceable).
OPENAI_API_KEY=
